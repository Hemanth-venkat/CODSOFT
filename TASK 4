# Task 4: Rock-Paper-Scissors Game (Modified Version)
import random

def play_game():
    options = ["rock", "paper", "scissors"]

    while True:
        player = input("Choose Rock, Paper, or Scissors: ").strip().lower()

        if player not in options:
            print("Oops! That's not a valid choice. Try again.")
            continue

        computer = random.choice(options)
        print(f"The computer picked: {computer}")

        if player == computer:
            print("It's a draw!")
        elif (player == "rock" and computer == "scissors") or \
             (player == "paper" and computer == "rock") or \
             (player == "scissors" and computer == "paper"):
            print("🎉 You win!")
        else:
            print("😢 You lose!")

        again = input("Want to play another round? (yes/no): ").strip().lower()
        if again != "yes":
            print("Thanks for playing! 👋")
            break

play_game()
